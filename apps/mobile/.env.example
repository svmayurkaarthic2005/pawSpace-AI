# Supabase Configuration (if using Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# API Configuration
# ==================
# 
# SETUP INSTRUCTIONS FOR PHYSICAL DEVICES:
# -----------------------------------------
# If you're running the app on a PHYSICAL Android device, you MUST update this
# to your computer's local IP address. The app won't connect to the backend otherwise!
#
# 🔍 HOW TO FIND YOUR COMPUTER'S IP ADDRESS:
#
#   Windows:
#     1. Open Command Prompt (cmd)
#     2. Type: ipconfig
#     3. Look for "IPv4 Address" under your WiFi or Ethernet adapter
#        Example: 192.168.1.100 or 172.31.32.1
#
#   Mac:
#     1. Open System Preferences > Network
#     2. Select your active connection (WiFi or Ethernet)
#     3. Your IP address is shown (e.g., 192.168.1.100)
#     OR open Terminal and run: ifconfig | grep "inet "
#
#   Linux:
#     1. Open Terminal
#     2. Type: ip addr show or ifconfig
#     3. Look for "inet" under your network interface (e.g., 192.168.1.100)
#
# 📝 EXAMPLES:
#
#   FOR ANDROID EMULATOR (default):
#     API_BASE_URL=http://10.0.2.2:5000/api/v1
#     (10.0.2.2 is the emulator's special alias for your host machine)
#
#   FOR PHYSICAL DEVICE on home WiFi:
#     API_BASE_URL=http://192.168.1.100:5000/api/v1
#     (Replace 192.168.1.100 with YOUR computer's actual IP)
#
#   FOR PHYSICAL DEVICE on office network:
#     API_BASE_URL=http://172.31.32.1:5000/api/v1
#     (Replace 172.31.32.1 with YOUR computer's actual IP)
#
# ⚠️ IMPORTANT NOTES:
#   - DO NOT use "localhost" or "127.0.0.1" for physical devices (won't work!)
#   - Your computer and phone MUST be on the same WiFi network
#   - Make sure Windows Firewall allows port 5000 (backend must be accessible)
#   - Make sure your backend server is running: npm run dev (in apps/backend)
#   - After changing this, restart Metro bundler: npm run start:reset
#
# 🚀 QUICK START:
#   1. Run ipconfig (Windows) or ifconfig (Mac/Linux)
#   2. Copy your IPv4 address (e.g., 192.168.1.100)
#   3. Replace the IP below: API_BASE_URL=http://YOUR_IP:5000/api/v1
#   4. Restart Metro: npm run start:reset
#   5. Rebuild app: npm run android
#
API_BASE_URL=http://10.0.2.2:5000/api/v1

# Google Places API (for location autocomplete)
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=AIzaSyC3fsrBckfPWI1VELnmdmaOWnLJpclkfVw

# Google Maps API (for react-native-maps)
GOOGLE_MAPS_API_KEY=AIzaSyC3fsrBckfPWI1VELnmdmaOWnLJpclkfVw

# Environment
NODE_ENV=development
