# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/pawspace
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme_in_production

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=changeme_in_production

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_min_32_chars_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── Groq AI ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key

# ─── Google Maps ──────────────────────────────────────────────────────────────
# REQUIRED: Get your API key from https://console.cloud.google.com/
# Enable these APIs: Geocoding API, Places API, Directions API
# Without this key, event creation and location features will FAIL
# See EVENTS_FIX_GUIDE.md for detailed setup instructions
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ─── Firebase (Push Notifications) ───────────────────────────────────────────
FIREBASE_PROJECT_ID=your_firebase_project_id
# Paste the full private key including -----BEGIN/END PRIVATE KEY----- lines
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
